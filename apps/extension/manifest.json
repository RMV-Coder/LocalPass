{
  "manifest_version": 3,
  "name": "LocalPass",
  "version": "0.1.0",
  "description": "Autofill logins from your local, offline LocalPass vault. No keys or passwords ever leave your machine.",
  "permissions": ["nativeMessaging", "activeTab", "scripting", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LocalPass",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
